<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AvaloniaApplication.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:const="clr-namespace:Ava.Xioa.Common.Const;assembly=Ava.Xioa.Common"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:global="clr-namespace:Ava.Xioa.Connectlayer.Global;assembly=Ava.Xioa.Connectlayer"
             xmlns:regions1="clr-namespace:Prism.Navigation.Regions;assembly=Prism"
             x:DataType="vm:MainViewViewModel"
             x:Class="AvaloniaApplication.Views.MainView">
    <Grid>
        <ContentControl 
            regions1:RegionManager.RegionName="{Binding Source={x:Static global:AppRegions.Instance},Path=Main}" />
        <!-- 对话框容器 -->
        <suki:SukiDialogHost Name="SukiDialogHost"/>
        <!-- 通知容器 -->
        <suki:SukiToastHost Name="SukiToastHost"/>
    </Grid>
</UserControl>